# ============================================================
#  UDSM SOCIAL HUB — Environment Variables
#  Nakili file hii → ".env" na badilisha values
#  KAMWE usifanye git commit ya .env!
# ============================================================

# ── Server ───────────────────────────────────────────────────
NODE_ENV=development
PORT=5000
FRONTEND_URL=http://localhost:3000

# ── Database (PostgreSQL) ─────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/udsm_hub
DB_HOST=localhost
DB_PORT=5432
DB_NAME=udsm_hub
DB_USER=postgres
DB_PASSWORD=your_password_here

# ── JWT Tokens ────────────────────────────────────────────────
JWT_SECRET=badilisha_hii_kuwa_ndefu_na_random_sana_2024!
JWT_REFRESH_SECRET=refresh_secret_tofauti_na_ya_juu_kabisa!
JWT_EXPIRES_IN=1d
JWT_REFRESH_EXPIRES_IN=30d

# ── Redis (Caching + Sessions) ────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Firebase (Push Notifications + Storage) ──────────────────
FIREBASE_PROJECT_ID=udsm-social-hub
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY\n-----END PRIVATE KEY-----"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@udsm-social-hub.iam.gserviceaccount.com
FIREBASE_STORAGE_BUCKET=udsm-social-hub.appspot.com

# ── Cloudinary (Image Upload) ─────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ── AI (Anthropic Claude) — chatbot, kuboresha posts, moderation ─
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── Email (Nodemailer) ────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@udsm-hub.com
SMTP_PASS=your_app_password

# ── Admin ────────────────────────────────────────────────────
ADMIN_EMAIL=admin@udsm.ac.tz
ADMIN_PASSWORD=Admin@UDSM2024!
